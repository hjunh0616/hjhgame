<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SNAKE_SYS</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap');
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:'Share Tech Mono',monospace;overflow:hidden}
  body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,255,65,0.03) 2px,rgba(0,255,65,0.03) 4px);pointer-events:none;z-index:10}
  h1{font-family:'Orbitron',monospace;color:#00ff41;font-size:1.4em;letter-spacing:.3em;text-shadow:0 0 20px #00ff41,0 0 40px #00ff41;margin-bottom:8px;animation:flicker 3s infinite}
  @keyframes flicker{0%,95%,100%{opacity:1}96%{opacity:.4}97%{opacity:1}98%{opacity:.2}99%{opacity:1}}
  #info{display:flex;gap:30px;margin-bottom:10px;color:#00ff41;font-size:.85em;letter-spacing:.1em}
  #info span{border:1px solid #00ff41;padding:3px 12px;text-shadow:0 0 8px #00ff41;box-shadow:0 0 8px rgba(0,255,65,.3)}
  canvas{border:1px solid #00ff41;box-shadow:0 0 30px rgba(0,255,65,.4),inset 0 0 30px rgba(0,255,65,.05);display:block}
  #msg{color:#00ff41;font-size:1em;letter-spacing:.15em;margin-top:10px;height:20px;text-shadow:0 0 10px #00ff41}
  #ctrl{color:#333;font-size:.75em;margin-top:8px;letter-spacing:.1em}
</style>
</head>
<body>
<h1>▶ SNAKE_SYS v2.0</h1>
<div id="info"><span>SCORE: <b id="sc">0</b></span><span>HIGH: <b id="hi">0</b></span><span>LVL: <b id="lv">1</b></span></div>
<canvas id="c" width="400" height="400"></canvas>
<div id="msg" id="msg">[ PRESS SPACE TO BOOT ]</div>
<div id="ctrl">↑↓←→ MOVE &nbsp;|&nbsp; SPACE START/PAUSE</div>
<script>
const c=document.getElementById('c'),ctx=c.getContext('2d'),
sc=document.getElementById('sc'),hi=document.getElementById('hi'),lv=document.getElementById('lv'),msg=document.getElementById('msg');
const SZ=20,COLS=20,ROWS=20;
let snake,dir,food,score,high=0,level,running,paused,loop;
function init(){
  snake=[{x:10,y:10},{x:9,y:10},{x:8,y:10}];
  dir={x:1,y:0};food=newFood();score=0;level=1;
  sc.textContent=0;lv.textContent=1;msg.textContent='';
}
function newFood(){
  let f;do{f={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)}}
  while(snake.some(s=>s.x===f.x&&s.y===f.y));return f;
}
function draw(){
  ctx.fillStyle='#000';ctx.fillRect(0,0,400,400);
  // grid
  ctx.strokeStyle='rgba(0,255,65,0.06)';ctx.lineWidth=.5;
  for(let i=0;i<=COLS;i++){ctx.beginPath();ctx.moveTo(i*SZ,0);ctx.lineTo(i*SZ,400);ctx.stroke()}
  for(let i=0;i<=ROWS;i++){ctx.beginPath();ctx.moveTo(0,i*SZ);ctx.lineTo(400,i*SZ);ctx.stroke()}
  // food
  ctx.shadowColor='#ff0055';ctx.shadowBlur=15;
  ctx.fillStyle='#ff0055';
  ctx.fillRect(food.x*SZ+2,food.y*SZ+2,SZ-4,SZ-4);
  ctx.shadowBlur=0;
  // snake
  snake.forEach((s,i)=>{
    const t=1-i/snake.length;
    ctx.shadowColor='#00ff41';ctx.shadowBlur=i===0?20:8;
    ctx.fillStyle=i===0?'#00ff41':`rgba(0,${Math.floor(255*t)},${Math.floor(65*t)},${t})`;
    ctx.fillRect(s.x*SZ+1,s.y*SZ+1,SZ-2,SZ-2);
    if(i===0){ctx.fillStyle='#000';ctx.fillRect(s.x*SZ+5,s.y*SZ+5,3,3);ctx.fillRect(s.x*SZ+12,s.y*SZ+5,3,3)}
  });
  ctx.shadowBlur=0;
}
function tick(){
  const head={x:snake[0].x+dir.x,y:snake[0].y+dir.y};
  if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS||snake.some(s=>s.x===head.x&&s.y===head.y)){
    gameOver();return;
  }
  snake.unshift(head);
  if(head.x===food.x&&head.y===food.y){
    score+=10*level;if(score>high)high=score;
    sc.textContent=score;hi.textContent=high;
    level=Math.floor(score/50)+1;lv.textContent=level;
    food=newFood();clearInterval(loop);loop=setInterval(tick,Math.max(60,200-level*15));
  }else snake.pop();
  draw();
}
function gameOver(){
  clearInterval(loop);running=false;
  msg.textContent='[ SYSTEM CRASH — SPACE TO RESTART ]';
  ctx.fillStyle='rgba(255,0,85,0.15)';ctx.fillRect(0,0,400,400);
  ctx.font='bold 28px Orbitron';ctx.fillStyle='#ff0055';ctx.textAlign='center';
  ctx.shadowColor='#ff0055';ctx.shadowBlur=20;
  ctx.fillText('GAME OVER',200,200);ctx.shadowBlur=0;
}
document.addEventListener('keydown',e=>{
  if(e.code==='Space'){
    if(!running){init();running=true;paused=false;loop=setInterval(tick,200);draw();}
    else if(paused){paused=false;loop=setInterval(tick,Math.max(60,200-level*15));msg.textContent='';}
    else{paused=true;clearInterval(loop);msg.textContent='[ PAUSED ]';}
    e.preventDefault();
  }
  const map={ArrowUp:{x:0,y:-1},ArrowDown:{x:0,y:1},ArrowLeft:{x:-1,y:0},ArrowRight:{x:1,y:0}};
  if(map[e.key]&&running&&!paused){
    const d=map[e.key];
    if(d.x!==(-dir.x)||d.y!==(-dir.y))dir=d;
    e.preventDefault();
  }
});
// initial draw
ctx.fillStyle='#000';ctx.fillRect(0,0,400,400);
ctx.font='bold 16px Orbitron';ctx.fillStyle='rgba(0,255,65,0.4)';ctx.textAlign='center';
ctx.fillText('PRESS SPACE TO START',200,200);
</script>
</body>
</html>
